// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Analysis {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  title             String
  content           String   // The extracted text
  summary           String?
  privacyScore      Int?
  dangerScore       Int?
  friendlinessScore Int?
  riskAnalysis      String?  // JSON string of findings
  fullResponse      String?  // JSON string of full AI response
  sourceUrl         String?
  sourceType        String   // 'url', 'text', 'file'
  userId            String?
  user              User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model User {
  id         String     @id @default(cuid())
  email      String?    @unique
  analyses   Analysis[]
  createdAt  DateTime   @default(now())
}
